{
	"name": "@selfagency/stately",
	"version": "0.1.3",
	"private": false,
	"description": "Pinia-inspired state management for Svelte 5 and SvelteKit with persistence, history, sync, and async orchestration.",
	"keywords": [
		"svelte",
		"sveltekit",
		"state management",
		"store",
		"reactivity",
		"persistence",
		"history",
		"time travel",
		"sync",
		"collaboration",
		"inspector",
		"vite-plugin"
	],
	"homepage": "https://stately.self.agency/",
	"bugs": {
		"url": "https://github.com/selfagency/stately/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/selfagency/stately.git"
	},
	"license": "MIT",
	"author": {
		"name": "Daniel Sieradski",
		"email": "daniel@self.agency",
		"url": "https://self.agency"
	},
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./persistence": {
			"types": "./dist/persistence/plugin.svelte.d.ts",
			"svelte": "./dist/persistence/plugin.svelte.js"
		},
		"./history": {
			"types": "./dist/history/plugin.svelte.d.ts",
			"svelte": "./dist/history/plugin.svelte.js"
		},
		"./sync": {
			"types": "./dist/sync/plugin.svelte.d.ts",
			"svelte": "./dist/sync/plugin.svelte.js"
		},
		"./async": {
			"types": "./dist/async/plugin.svelte.d.ts",
			"svelte": "./dist/async/plugin.svelte.js"
		},
		"./inspector": {
			"types": "./dist/inspector/index.d.ts",
			"svelte": "./dist/inspector/index.js"
		},
		"./inspector/vite": {
			"types": "./dist/inspector/vite-plugin.d.ts",
			"svelte": "./dist/inspector/vite-plugin.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"svelte": "./dist/testing.js"
		}
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"skills"
	],
	"scripts": {
		"build": "vite build && pnpm run package:dist",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo --watch",
		"dev": "vite dev",
		"docs:build": "vitepress build docs",
		"docs:dev": "vitepress dev docs",
		"docs:preview": "vitepress preview docs",
		"format": "eslint . --fix --concurrency 6 && prettier --write .",
		"format:check": "prettier --check .",
		"knip": "knip",
		"lint": "eslint . --concurrency 6 && prettier --check .",
		"prepack": "pnpm run package:dist",
		"package:dist": "svelte-kit sync && svelte-package && node scripts/write-dist-package.js && publint",
		"prepare": "husky && svelte-kit sync || echo ''",
		"preview": "vite preview",
		"release": "node scripts/release.js",
		"release:dry-run": "node scripts/release.js --dry-run",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest",
		"validate:staged": "lint-staged"
	},
	"dependencies": {
		"@lucide/svelte": "^1.8.0",
		"lz-string": "^1.5.0"
	},
	"devDependencies": {
		"@changesets/changelog-git": "^0.2.1",
		"@changesets/cli": "^2.30.0",
		"@codecov/vite-plugin": "^1.9.1",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@octokit/rest": "^22.0.1",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/cli": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "25.6.0",
		"@typescript/native-preview": "7.0.0-dev.20260413.1",
		"@vitest/browser-playwright": "^4.1.4",
		"@vitest/coverage-v8": "^4.1.4",
		"bits-ui": "^2.17.3",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.5.0",
		"husky": "^9.1.7",
		"knip": "^6.4.1",
		"lint-staged": "^16.4.0",
		"ora": "^9.3.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.2",
		"prettier-plugin-organize-attributes": "^1.0.0",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"runed": "^0.37.1",
		"shiki": "^4.0.2",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"svelte-toolbelt": "^0.10.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.4",
		"vitest-browser-svelte": "^2.1.1"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
