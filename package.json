{
	"name": "@selfagency/stately",
	"version": "0.1.0",
	"description": "Pinia-inspired state management for Svelte 5 and SvelteKit with persistence, history, sync, and async orchestration.",
	"private": false,
	"keywords": [
		"svelte",
		"sveltekit",
		"state management",
		"store",
		"reactivity",
		"persistence",
		"history",
		"time travel",
		"sync",
		"collaboration"
	],
	"homepage": "https://stately.self.agency/",
	"bugs": {
		"url": "https://github.com/selfagency/stately/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/selfagency/stately.git"
	},
	"license": "MIT",
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"scripts": {
		"build": "vite build && npm run prepack",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo --watch",
		"dev": "vite dev",
		"docs:build": "vitepress build docs",
		"docs:dev": "vitepress dev docs",
		"docs:preview": "vitepress preview docs",
		"format": "eslint . --fix && prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . && prettier --check .",
		"prepack": "svelte-kit sync && svelte-package && node scripts/write-dist-package.js && publint",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"release": "node scripts/release.js",
		"release:dry-run": "pnpm run check && pnpm run lint && pnpm run test && pnpm run build && node scripts/release.js --dry-run",
		"release:version": "changeset version",
		"test": "npm run test:unit -- --run",
		"test:coverage": "vitest --coverage",
		"test:unit": "vitest",
		"validate:pre-push": "pnpm run check && pnpm run test",
		"validate:staged": "lint-staged"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@changesets/changelog-git": "^0.2.1",
		"@codecov/vite-plugin": "^1.9.1",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "25.6.0",
		"@typescript/native-preview": "7.0.0-dev.20260410.1",
		"@vitest/browser-playwright": "^4.1.4",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.2",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.3",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.8",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.4",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"lz-string": "^1.5.0"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
