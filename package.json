{
  "name": "@selfagency/stately",
  "version": "0.1.4",
  "private": false,
  "description": "Pinia-inspired state management for Svelte 5 and SvelteKit with persistence, history, sync, and async orchestration.",
  "keywords": [
    "svelte",
    "sveltekit",
    "state management",
    "store",
    "reactivity",
    "persistence",
    "history",
    "time travel",
    "sync",
    "collaboration",
    "inspector",
    "vite-plugin"
  ],
  "homepage": "https://stately.self.agency/",
  "bugs": {
    "url": "https://github.com/selfagency/stately/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/selfagency/stately.git"
  },
  "license": "MIT",
  "author": {
    "name": "Daniel Sieradski",
    "email": "daniel@self.agency",
    "url": "https://self.agency"
  },
  "sideEffects": ["**/*.css"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/plugin.svelte.d.ts",
      "svelte": "./dist/persistence/plugin.svelte.js"
    },
    "./history": {
      "types": "./dist/history/plugin.svelte.d.ts",
      "svelte": "./dist/history/plugin.svelte.js"
    },
    "./sync": {
      "types": "./dist/sync/plugin.svelte.d.ts",
      "svelte": "./dist/sync/plugin.svelte.js"
    },
    "./async": {
      "types": "./dist/async/plugin.svelte.d.ts",
      "svelte": "./dist/async/plugin.svelte.js"
    },
    "./inspector": {
      "types": "./dist/inspector/index.d.ts",
      "svelte": "./dist/inspector/index.js"
    },
    "./inspector/vite": {
      "types": "./dist/inspector/vite-plugin.d.ts",
      "svelte": "./dist/inspector/vite-plugin.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "svelte": "./dist/testing.js"
    }
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "!dist/**/*.test.*", "!dist/**/*.spec.*", "skills"],
  "scripts": {
    "build": "vite build && pnpm run package:dist",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo --watch",
    "dev": "vite dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "knip": "knip",
    "lint": "biome ci .",
    "prepack": "pnpm run package:dist",
    "package:dist": "svelte-kit sync && svelte-package && node scripts/write-dist-package.js && publint",
    "prepare": "husky && svelte-kit sync || echo ''",
    "preview": "vite preview",
    "release": "node scripts/release.js",
    "release:dry-run": "node scripts/release.js --dry-run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest",
    "validate:staged": "lint-staged"
  },
  "dependencies": {
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@codecov/vite-plugin": "^2.0.1",
    "@internationalized/date": "^3.12.2",
    "@octokit/rest": "^22.0.1",
    "@shikijs/langs": "^4.2.0",
    "@shikijs/themes": "^4.2.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.67.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "26.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260622.1",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "knip": "^6.18.0",
    "lint-staged": "^17.0.8",
    "ora": "^9.4.1",
    "playwright": "^1.61.0",
    "publint": "^0.3.21",
    "runed": "^0.37.1",
    "shiki": "^4.2.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-toolbelt": "^0.10.6",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "optionalDependencies": {
    "@lucide/svelte": "^1.21.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
